   "outputs": [],
   "source": [
    "# FIX: Original dropped neutral (3-star) reviews silently with label=-1.\n",
    "# This is a valid approach but must be DOCUMENTED and VERIFIED.\n",
    "# Neutral reviews carry ambiguous signal — binary classification benefits from excluding them.\n",
    "\n",
    "def create_sentiment_label(rating: float) -> int:\n",
    "    \"\"\"\n",
    "    Returns:\n",
    "        1  → Positive  (4-5 stars)\n",
    "        0  → Negative  (1-2 stars)\n",
    "        -1 → Neutral   (3 stars)  — excluded from training\n",
    "    \"\"\"\n",
    "    if rating >= 4:\n",
    "        return 1\n",
    "    elif rating <= 2:\n",
    "        return 0\n",
    "    else:\n",
    "        return -1\n",
    "\n",
    "df['sentiment'] = df['overall'].apply(create_sentiment_label)\n",
    "\n",
    "neutral_count = (df['sentiment'] == -1).sum()\n",
    "print(f\"Neutral (3-star) reviews excluded: {neutral_count:,} ({neutral_count/len(df)*100:.1f}%)\")\n",
    "\n",
    "df = df[df['sentiment'] != -1].reset_index(drop=True)\n",
    "print(f\"Dataset after filtering: {df.shape}\")\n",
    "\n",
    "# Class balance check\n",
    "class_counts = df['sentiment'].value_counts()\n",
    "print(\"\\nClass distribution:\")\n",
    "print(class_counts)\n",
    "print(f\"Imbalance ratio (Pos/Neg): {class_counts[1]/class_counts[0]:.2f}x\")\n"
   ]
