   "cell_type": "markdown",
   "id": "34083edc",
   "metadata": {},
   "source": [
    "## 5. Text Preprocessing Pipeline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "431b8c66",
   "metadata": {},
   "outputs": [],
   "source": [
    "# FIX: Original used sklearn ENGLISH_STOP_WORDS (minimal set) and NO lemmatization.\n",
    "# NLTK stopwords are more comprehensive; lemmatization reduces vocabulary better than stemming.\n",
    "\n",
    "lemmatizer = WordNetLemmatizer()\n",
    "STOP_WORDS  = set(stopwords.words('english'))\n",
    "\n",
    "# FIX: Original regex r'http\\\\S+' was double-escaped — would NOT match URLs.\n",
    "URL_RE      = re.compile(r'https?://\\S+|www\\.\\S+')\n",
    "NON_ALPHA   = re.compile(r'[^a-zA-Z\\s]')\n",
    "MULTI_SPACE = re.compile(r'\\s+')\n",
    "\n",
    "def clean_text(text: str) -> str:\n",
    "    \"\"\"\n",
    "    Pipeline:\n",
    "        1. Lowercase\n",
    "        2. Remove URLs\n",
    "        3. Remove non-alphabetic chars\n",
    "        4. Tokenise\n",
    "        5. Remove stopwords\n",
    "        6. Lemmatize\n",
    "        7. Rejoin\n",
    "    \"\"\"\n",
    "    text = str(text).lower()\n",
    "    text = URL_RE.sub(' ', text)\n",
    "    text = NON_ALPHA.sub(' ', text)\n",
    "    words = MULTI_SPACE.sub(' ', text).strip().split()\n",
    "    words = [lemmatizer.lemmatize(w) for w in words if w not in STOP_WORDS and len(w) > 2]\n",
    "    return ' '.join(words)\n",
    "\n",
    "df['clean_review'] = df['reviewText'].apply(clean_text)\n",
    "\n",
    "# Sanity check\n",
    "print(\"Original:\", df['reviewText'].iloc[0][:120])\n",
    "print(\"Cleaned: \", df['clean_review'].iloc[0][:120])\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a3bc1d99",
   "metadata": {},
   "source": [
    "## 6. Train-Test Split\n",
    "> **FIX:** Split happens BEFORE tokenisation to prevent data leakage. Tokenizer must only be `fit` on training data."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e9d763a0",
   "metadata": {},
   "outputs": [],
   "source": [
    "# FIX (CRITICAL — DATA LEAKAGE): Original fitted tokenizer on the FULL dataset,\n",
    "# then split. The tokenizer learned vocabulary from test samples → data leakage.\n",
    "# Correct approach: split first, fit tokenizer ONLY on X_train.\n",
    "\n",
    "X = df['clean_review'].values\n",
    "y = df['sentiment'].values\n",
    "\n",
    "X_train_raw, X_test_raw, y_train, y_test = train_test_split(\n",
    "    X, y,\n",
    "    test_size=0.20,\n",
    "    random_state=SEED,\n",
    "    stratify=y          # preserves class ratio\n",
    ")\n",
    "\n",
    "print(f\"Train size : {len(X_train_raw):,}\")\n",
    "print(f\"Test  size : {len(X_test_raw):,}\")\n",
    "print(f\"Train class balance: {np.bincount(y_train)}\")\n",
    "print(f\"Test  class balance: {np.bincount(y_test)}\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9fa8c32c",
   "metadata": {},
   "source": [
    "## 7. Traditional ML Baseline (Logistic Regression, Naive Bayes, Random Forest)\n",
    "> These are often overlooked but provide strong, fast, interpretable baselines."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "91babb58",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Class weights for imbalance\n",
    "cw = compute_class_weight('balanced', classes=np.unique(y_train), y=y_train)\n",
    "class_weight_dict = {0: cw[0], 1: cw[1]}\n",
    "print(\"Class weights:\", class_weight_dict)\n",
    "\n",
    "# Define pipelines — TF-IDF fitted only inside pipeline (no leakage)\n",
    "ml_pipelines = {\n",
    "    'Logistic Regression': Pipeline([\n",
    "        ('tfidf', TfidfVectorizer(max_features=30000, ngram_range=(1, 2), sublinear_tf=True)),\n",
    "        ('clf',   LogisticRegression(max_iter=500, class_weight='balanced', random_state=SEED))\n",
    "    ]),\n",
    "    'Naive Bayes': Pipeline([\n",
    "        ('tfidf', TfidfVectorizer(max_features=30000, ngram_range=(1, 2), sublinear_tf=True)),\n",
    "        ('clf',   MultinomialNB())\n",
    "    ]),\n",
    "    'Random Forest': Pipeline([\n",
    "        ('tfidf', TfidfVectorizer(max_features=10000, ngram_range=(1, 1))),\n",
    "        ('clf',   RandomForestClassifier(n_estimators=100, class_weight='balanced', random_state=SEED, n_jobs=-1))\n",
    "    ]),\n",
    "}\n",
    "\n",
    "ml_results = []\n",
    "\n",
    "for name, pipe in ml_pipelines.items():\n",
    "    pipe.fit(X_train_raw, y_train)\n",
    "    preds     = pipe.predict(X_test_raw)\n",
    "    proba     = pipe.predict_proba(X_test_raw)[:, 1]\n",
    "\n",
    "    ml_results.append({\n",
    "        'Model'    : name,\n",
    "        'Accuracy' : accuracy_score(y_test, preds),\n",
    "        'Precision': precision_score(y_test, preds),\n",
    "        'Recall'   : recall_score(y_test, preds),\n",
    "        'F1 Score' : f1_score(y_test, preds),\n",
    "        'ROC-AUC'  : roc_auc_score(y_test, proba),\n",
    "    })\n",
    "    print(f\"✓ {name} done\")\n",
    "\n",
    "ml_results_df = pd.DataFrame(ml_results).set_index('Model').round(4)\n",
    "print(\"\\n\" + ml_results_df.to_string())\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b43f468a",
   "metadata": {},
   "source": [
    "## 8. Tokenisation for Deep Learning\n",
    "> Tokenizer fitted ONLY on training data."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "44a78f20",
   "metadata": {},
   "outputs": [],
   "source": [
    "MAX_WORDS = 20000\n",
    "MAX_LEN   = 200   # FIX: 150 truncated many medium-length reviews; 200 is safer\n",
    "\n",
    "# FIX: Fit tokenizer ONLY on training data to avoid leakage\n",
    "tokenizer = Tokenizer(num_words=MAX_WORDS, oov_token='<OOV>')\n",
    "tokenizer.fit_on_texts(X_train_raw)\n",
    "\n",
    "def encode(texts):\n",
    "    seqs = tokenizer.texts_to_sequences(texts)\n",
    "    return pad_sequences(seqs, maxlen=MAX_LEN, padding='post', truncating='post')\n",
    "\n",
    "X_train = encode(X_train_raw)\n",
    "X_test  = encode(X_test_raw)\n",
    "\n",
    "print(f\"X_train shape: {X_train.shape}\")\n",
    "print(f\"X_test  shape: {X_test.shape}\")\n",
    "print(f\"Vocabulary size: {len(tokenizer.word_index):,}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "160f409f",
   "metadata": {},
   "outputs": [],
   "source": [
    "# FIX: Original ignored class imbalance in DL training entirely.\n",
    "# sample_weight or class_weight must be passed to model.fit().\n",
    "\n",
    "sample_weights = np.where(y_train == 1, cw[1], cw[0])\n",
    "print(\"Sample weight stats — min:\", sample_weights.min().round(3),\n",
    "      \"max:\", sample_weights.max().round(3))\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "54c1e38e",
   "metadata": {},
   "source": [
    "## 9. Deep Learning Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "df238794",
   "metadata": {},
   "outputs": [],
   "source": [
    "# FIX: Added ReduceLROnPlateau — helps escape local minima; original only had EarlyStopping.\n",
    "callbacks = [\n",
    "    EarlyStopping(monitor='val_loss', patience=3, restore_best_weights=True),\n",
    "    ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=2, min_lr=1e-6, verbose=0)\n",
    "]\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "de7cf9ac",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Model Factory ────────────────────────────────────────────────────────────\n",
    "\n",
    "def build_lstm():\n",
    "    m = Sequential([\n",
    "        Embedding(MAX_WORDS, 128, input_length=MAX_LEN),\n",
    "        LSTM(64, return_sequences=False),\n",
    "        Dropout(0.5),\n",
    "        Dense(1, activation='sigmoid')\n",
    "    ], name='LSTM')\n",
    "    m.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])\n",
    "    return m\n",
    "\n",
    "def build_bilstm():\n",
    "    m = Sequential([\n",
    "        Embedding(MAX_WORDS, 128, input_length=MAX_LEN),\n",
    "        Bidirectional(LSTM(64)),\n",
    "        Dropout(0.5),\n",
    "        Dense(1, activation='sigmoid')\n",
    "    ], name='BiLSTM')\n",
    "    m.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])\n",
    "    return m\n",
    "\n",
    "def build_gru():\n",
    "    m = Sequential([\n",
    "        Embedding(MAX_WORDS, 128, input_length=MAX_LEN),\n",
    "        GRU(64),\n",
    "        Dropout(0.5),\n",
    "        Dense(1, activation='sigmoid')\n",
    "    ], name='GRU')\n",
    "    m.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])\n",
    "    return m\n",
    "\n",
    "def build_bigru():\n",
    "    m = Sequential([\n",
    "        Embedding(MAX_WORDS, 128, input_length=MAX_LEN),\n",
    "        Bidirectional(GRU(64)),\n",
    "        Dropout(0.5),\n",
    "        Dense(1, activation='sigmoid')\n",
    "    ], name='BiGRU')\n",
    "    m.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])\n",
    "    return m\n",
    "\n",
    "def build_cnn():\n",
    "    m = Sequential([\n",
    "        Embedding(MAX_WORDS, 128, input_length=MAX_LEN),\n",
    "        Conv1D(128, kernel_size=5, activation='relu'),\n",
    "        GlobalMaxPooling1D(),\n",
    "        Dropout(0.5),\n",
    "        Dense(1, activation='sigmoid')\n",
    "    ], name='CNN')\n",
    "    m.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])\n",
    "    return m\n",
    "\n",
    "print(\"Model builders defined.\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4f52685b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Train all DL models ──────────────────────────────────────────────────────\n",
    "# FIX: Original trained LSTM but compared it against Bi-LSTM / GRU / Bi-GRU that\n",
    "# were NEVER trained — they were just built with random weights.\n",
    "# All models are now properly trained.\n",
    "\n",
    "FIT_PARAMS = dict(\n",
    "    x=X_train,\n",
    "    y=y_train,\n",
    "    validation_split=0.15,   # FIX: use 15% of train (not 20%) to preserve training data\n",
    "    epochs=10,\n",
    "    batch_size=64,\n",
    "    sample_weight=sample_weights,\n",
    "    callbacks=callbacks,\n",
    "    verbose=0\n",
    ")\n",
    "\n",
    "dl_models = {\n",
    "    'LSTM'   : build_lstm(),\n",
