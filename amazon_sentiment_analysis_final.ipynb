   "source": [
    "# ── Unified evaluation function ──────────────────────────────────────────────\n",
    "# FIX: Original evaluate_model was DEFINED TWICE (duplicate function).\n",
    "# FIX: ROC-AUC was completely missing from evaluation.\n",
    "\n",
    "def evaluate_dl_model(model, name: str) -> dict:\n",
    "    \"\"\"Evaluate a Keras model and return a metrics dict.\"\"\"\n",
    "    proba = model.predict(X_test, verbose=0).ravel()\n",
    "    preds = (proba > 0.5).astype(int)\n",
    "    return {\n",
    "        'Model'    : name,\n",
    "        'Accuracy' : round(accuracy_score(y_test, preds), 4),\n",
    "        'Precision': round(precision_score(y_test, preds), 4),\n",
    "        'Recall'   : round(recall_score(y_test, preds), 4),\n",
    "        'F1 Score' : round(f1_score(y_test, preds), 4),\n",
    "        'ROC-AUC'  : round(roc_auc_score(y_test, proba), 4),\n",
    "    }\n",
    "\n",
    "dl_results = [evaluate_dl_model(model, name) for name, model in dl_models.items()]\n",
    "dl_results_df = pd.DataFrame(dl_results).set_index('Model')\n",
    "\n",
    "print(\"\\n=== Deep Learning Results ===\")\n",
    "print(dl_results_df.to_string())\n"
   ]
