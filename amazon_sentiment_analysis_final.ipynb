    "    cv=cv,\n",
    "    scoring='f1',\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "print(f\"5-Fold CV F1 Scores: {cv_scores.round(4)}\")\n",
    "print(f\"Mean F1 : {cv_scores.mean():.4f} ± {cv_scores.std():.4f}\")\n"
