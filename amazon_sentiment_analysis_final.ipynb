    "idx      = np.random.choice(len(X), SAMPLE_N, replace=False)\n",
    "\n",
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=SEED)\n",
    "cv_scores = cross_val_score(\n",
