    "axes[0].set_xlabel('Coefficient Value')\n",
    "\n",
    "axes[1].barh(vocab[top_neg], np.abs(coefs[top_neg]), color='#e74c3c')\n",
    "axes[1].set_title('Top Negative Tokens (LR Coefficients)', fontweight='bold')\n",
    "axes[1].set_xlabel('|Coefficient Value|')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('feature_importance.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Insight: LR coefficients reveal which words drive positive vs negative sentiment predictions.\")\n"
